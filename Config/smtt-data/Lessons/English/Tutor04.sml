	<Lesson>
		<Title>Alphabet Break</Title>
		<Author>Sao Mai Training Team</Author>
		<Description>By Kenn Nesbitt</Description>
		<ExpectedSpeed>180</ExpectedSpeed>
		<ExpectedPoint>95</ExpectedPoint>
		<TextToType>I'm learning all my ABC's.
